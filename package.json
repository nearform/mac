{
  "name": "mac",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MAC (Mastra Agentic Coding) — reusable Mastra building blocks + a deployable reference app. GitHub repo-maintenance agent.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nearform/mac.git"
  },
  "homepage": "https://github.com/nearform/mac#readme",
  "bugs": {
    "url": "https://github.com/nearform/mac/issues"
  },
  "packageManager": "pnpm@10.18.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm -C packages/mac-cli start dev",
    "dev:server": "pnpm -C apps/server dev",
    "dev:tunnel": "concurrently -k -n mac,tunnel -c cyan,yellow \"pnpm dev\" \"pnpm tunnel\"",
    "start": "pnpm -C packages/mac-cli start serve",
    "studio": "pnpm -C apps/server studio",
    "cli": "pnpm -C packages/mac-cli start",
    "link-cli": "pnpm -C packages/mac-cli build && cd packages/mac-cli && pnpm link --global",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "tunnel": "node scripts/tunnel.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "localtunnel": "^2.0.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "protobufjs"
    ]
  }
}
