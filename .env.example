# ── Last Light — Environment Variables ─────────────────────
# Copy to .env and fill in your values:  cp .env.example .env

# ── GitHub App (required) ────────────────────────────────
# Create at: https://github.com/settings/apps/new
# See README for full setup instructions
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_PATH=./your-app-name.private-key.pem
GITHUB_APP_INSTALLATION_ID=789012

# ── Webhook (required) ──────────────────────────────────
# Must match the secret configured in your GitHub App webhook settings
WEBHOOK_SECRET=your-webhook-secret

# ── Domain (used by Caddy for TLS) ─────────────────────────────────────────
# DOMAIN=lastlight.example.com
#
# Public URL embedded in outbound messages (Slack "Live progress" link, etc.).
# If unset, derived as https://<DOMAIN>. Set explicitly when DOMAIN is not the
# externally-reachable host (reverse proxy, custom port, etc.). No trailing /.
# PUBLIC_URL=https://lastlight.example.com

# ── PR review as a blocking check ──────────────────────────────────────────
# When 1, the pr-review workflow posts a `last-light/review` Check Run on the
# PR's head SHA — yellow on workflow start, then success/failure/neutral when
# the agent's review lands. Add `last-light/review` to the repo's required
# status checks in branch protection to gate merges on the review.
#
# Requires the GitHub App to have Checks: Read and write permission. Without
# it, check-run posts will fail with 403 (the workflow itself still runs).
# REVIEW_POSTS_CHECK=1

# ── Model provider API keys ────────────────────────────────────────────────
# agentic-pi / pi-ai is provider-agnostic. Set the API key matching whatever
# LASTLIGHT_MODEL points at (default: anthropic/claude-sonnet-4-6). Mix
# freely if LASTLIGHT_MODELS routes different phases to different providers.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-v1-...      # many models, one key — https://openrouter.ai/keys

# ── Slack OAuth (optional — enables "Login with Slack" on dashboard) ──
# Create a Slack app at https://api.slack.com/apps and enable "Sign in with Slack"
# Redirect URI must be: https://<your-host>/admin/api/oauth/slack/callback
# SLACK_OAUTH_CLIENT_ID=
# SLACK_OAUTH_CLIENT_SECRET=
# SLACK_OAUTH_REDIRECT_URI=http://localhost:8644/admin/api/oauth/slack/callback
# SLACK_ALLOWED_WORKSPACE=your-team-id-or-domain   # Restrict to one workspace

# ── GitHub OAuth (optional — enables "Login with GitHub" on dashboard) ──
# Uses the existing GitHub App's OAuth capability. Client ID is shown on the
# App settings page; generate a client secret in the same page under
# "Client secrets". Redirect URI must be:
# https://<your-host>/admin/api/oauth/github/callback
#
# GITHUB_ALLOWED_ORG is REQUIRED when OAuth is enabled. Set to a GitHub org
# slug to restrict login to confirmed org members, or to "*" to explicitly
# allow ANY authenticated GitHub user (use with care — this is the public
# internet). If client id/secret are set without this, OAuth is disabled.
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_REDIRECT_URI=http://localhost:8644/admin/api/oauth/github/callback
# GITHUB_ALLOWED_ORG=              # org slug, or "*" to allow any GitHub user

# ── Sandbox backend ────────────────────────────────────────────────────────
# Workflow phases run in an isolated sandbox. Pick one:
#   gondolin = agentic-pi's QEMU micro-VM (default, requires /dev/kvm on Linux
#              or HVF on macOS — silently hangs without it)
#   docker   = sibling Docker container per phase (requires the lastlight-sandbox
#              image and host docker socket access)
#   none     = unsandboxed, in-process — dev only, agent can read/write host fs
# LASTLIGHT_SANDBOX=gondolin

# ── Overlay configuration (optional) ──────────────────────────────────────
# LASTLIGHT_OVERLAY_DIR points at a trusted deployment directory. At startup,
# Last Light loads config/default.yaml, overlays $LASTLIGHT_OVERLAY_DIR/config.yaml
# if present, then applies legacy env overrides below. The overlay may also
# provide workflows/, workflows/prompts/, skills/, and agent-context/ files.
# Restart the harness after changing overlay files.
# LASTLIGHT_OVERLAY_DIR=/etc/lastlight

# ── Agent Settings (optional) ───────────────────────────
# Legacy OPENCODE_* names below are still read as fallbacks for the
# LASTLIGHT_* names, so existing .env files from the OpenCode era keep working.
# LASTLIGHT_MODEL=anthropic/claude-sonnet-4-6   # Default model (provider/model string)
# LASTLIGHT_MODELS={"architect":"openai/gpt-5.5","triage":"openrouter/google/gemini-2.5-flash","chat":"anthropic/claude-haiku-4-5-20251001"}
# Task types: guardrails, architect, executor, reviewer, fix, pr, pr-fix, resume, triage, review, health, chat
# LASTLIGHT_THINKING=high                # Default reasoning effort: off | minimal | low | medium | high | xhigh
# LASTLIGHT_THINKINGS={"architect":"high","triage":"minimal"}  # Per-phase overrides
# LASTLIGHT_SESSIONS_DIR=./data/agent-sessions  # Where the dashboard reads JSONL envelopes
# MAX_TURNS=200                          # Max agent turns per invocation
# PORT=8644                              # Webhook listener port
# STATE_DIR=./data                       # Persistent state directory
# BOT_LOGIN=last-light[bot]              # Bot login for self-event filtering

# ── Admin Dashboard ────────────────────────────────────────────────────────
# ADMIN_PASSWORD=                        # Dashboard login password
# ADMIN_SECRET=                          # HMAC secret for session tokens (auto-generated by setup)
